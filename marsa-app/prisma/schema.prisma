  managerSignatureImage String?          @db.Text
  managerStampImage     String?          @db.Text
  managerSignedAt       DateTime?
  managerName           String?
  clientSignature       String?          @db.Text
  clientSignedAt        DateTime?
  clientSignedIP        String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  linkedProjects Project[]      @relation("ProjectContract")
  installments   ContractPaymentInstallment[]
  tickets        Ticket[]
  addenda        ContractAddendum[]

  @@map("contracts")
}

model ContractPaymentInstallment {
  id           String   @id @default(cuid())
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  title        String
  amount       Float
  percentage   Float?
  dueAfterDays Int?
  order        Int      @default(0)
  linkedTaskId   String?   @unique
  linkedTask     Task?    @relation("InstallmentTask", fields: [linkedTaskId], references: [id])
  isLocked       Boolean  @default(false)
  paidAmount     Float    @default(0)
  paymentStatus  String   @default("UNPAID")
  paidAt         DateTime?
  approvedById   String?
  rolloverToId   String?
  // Partial-payment workflow: an executor whose task is blocked on this
  // installment can request a partial amount from admin/manager; once
  // approved the amount is added to paidAmount and the task unlocks if
  // the partial covers the full sum.
  partialPaymentRequest Float?
  partialPaymentType    String?     // "PARTIAL" | "FULL"
  partialApprovedById   String?
  partialApprovedAt     DateTime?
  // Grace-period workflow: executor asks for X days of unlocked
  // access while the payment is still outstanding. After approval
  // the task is temporarily unlocked until gracePeriodEnd, at which
  // point computeCanStart re-locks it automatically.
  gracePeriodDays       Int?
  gracePeriodEnd        DateTime?
  gracePeriodApproved   Boolean  @default(false)
  // Receipt-confirmation workflow: an executor (or admin/manager) records
  // that a payment was received from the client; the installment unlocks
  // immediately for downstream work, but stays in PENDING_CONFIRMATION
  // until a finance approver confirms or rejects. A REJECT re-locks the
  // installment and the linked task and stores the reason.
  recordedById          String?
  recordedAt            DateTime?
  confirmedById         String?
  confirmedAt           DateTime?
  confirmationStatus    String?     // PENDING_CONFIRMATION | CONFIRMED | REJECTED
  rejectionReason       String?
  tickets        Ticket[]
  createdAt    DateTime @default(now())

  @@map("contract_payment_installments")
}

