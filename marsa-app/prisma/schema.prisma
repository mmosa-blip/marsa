  providerStatus      String             @default("PENDING")
  completedAt         DateTime?
  completedByProvider Boolean            @default(false)
  reminders           ProviderReminder[]

  @@map("task_external_providers")
}

model ProviderReminder {
  id           String               @id @default(cuid())
  linkId       String
  link         TaskExternalProvider  @relation(fields: [linkId], references: [id], onDelete: Cascade)
  remindedAt   DateTime             @default(now())
  remindedById String
  remindedBy   User                 @relation("ReminderSender", fields: [remindedById], references: [id])
  note         String?

  @@map("provider_reminders")
}

model TaskGovernmentHold {
  id        String             @id @default(cuid())
  taskId    String
  task      Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  heldAt    DateTime           @default(now())
  heldById  String
  heldBy    User               @relation("GovernmentHoldCreator", fields: [heldById], references: [id])
  entity    String?
  isActive  Boolean            @default(true)
  updates   GovernmentUpdate[]

  @@map("task_government_holds")
}

model GovernmentUpdate {
  id        String             @id @default(cuid())
  holdId    String
  hold      TaskGovernmentHold @relation(fields: [holdId], references: [id], onDelete: Cascade)
  note      String             @db.Text
  addedAt   DateTime           @default(now())
  addedById String
  addedBy   User               @relation("GovUpdateCreator", fields: [addedById], references: [id])

  @@map("government_updates")
}

// ===== اللوائح والإرشادات =====

model SystemPolicy {
  id            String               @id @default(cuid())
  title         String
  slug          String               @unique
  content       String               @db.Text
  isPublished   Boolean              @default(true)
  order         Int                  @default(0)
  icon          String?
  updatedAt     DateTime             @updatedAt
  updatedById   String?
  updatedBy     User?                @relation("PolicyEditor", fields: [updatedById], references: [id])
  createdAt     DateTime             @default(now())
  notifications PolicyNotification[]

  @@map("system_policies")
}

model PolicyNotification {
  id        String       @id @default(cuid())
  policyId  String
  policy    SystemPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation("PolicyNotifications", fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime?
  createdAt DateTime     @default(now())

  @@unique([policyId, userId])
  @@map("policy_notifications")
}

// ===== Departments =====

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  nameEn      String?
  // Human-readable department number — backfilled from the four canonical
  // departments. Used as the 2-digit segment of Project.projectCode.
  deptNumber  Int?     @unique
  description String?  @db.Text
  color       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects         Project[]
  services         Service[]
  serviceTemplates ServiceTemplate[]
  tasks            Task[]
  employees        UserDepartment[]  @relation("DepartmentUsers")
  opportunities    Opportunity[]
  deptPayments     DepartmentPayment[] @relation("DepartmentPayments")
  docTypes         DocType[]         @relation("DepartmentDocTypes")
  documentGroups   DocumentGroup[]   @relation("DepartmentDocGroups")
  assignmentPool   DepartmentAssignmentPool[]

  @@map("departments")
}

model DepartmentAssignmentPool {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  // ROUND_ROBIN = rotate managerId across pool members based on lastAssigned
  // ALL         = every project goes to the entire pool (managerId = first member)
  mode         String     @default("ROUND_ROBIN")
  order        Int        @default(0)
  lastAssigned DateTime?
  createdAt    DateTime   @default(now())

  @@unique([departmentId, userId])
  @@map("department_assignment_pools")
}

model UserDepartment {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation("UserDepartments", fields: [userId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation("DepartmentUsers", fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, departmentId])
  @@map("user_departments")
}

// ===== Opportunities (CRM) =====

enum OpportunityType {
  INVESTMENT
  REAL_ESTATE
  PREMIUM_RESIDENCY
  SERVICES
}

enum OpportunityStage {
  CONTACT
  INTEREST
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Opportunity {
  id                String            @id @default(cuid())
  title             String
  description       String?           @db.Text
  type              OpportunityType
  stage             OpportunityStage  @default(CONTACT)
  value             Float?
  probability       Int               @default(0)
  contactName       String?
  contactPhone      String?
  contactEmail      String?
  marketerName      String?
  notes             String?           @db.Text
  expectedCloseDate DateTime?
  closedAt          DateTime?
  convertedProjectId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  assigneeId   String?
  assignee     User?       @relation("OpportunityAssignee", fields: [assigneeId], references: [id])

  clientId     String?
  client       User?       @relation("OpportunityClient", fields: [clientId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  activities   OpportunityActivity[]

  @@map("opportunities")
}

model OpportunityActivity {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  userId        String?
  userName      String?
  action        String
  details       String?     @db.Text
  createdAt     DateTime    @default(now())

  @@map("opportunity_activities")
}

// ===== Department Payments =====

enum DeptPaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum DeptPaymentMethod {
  BANK_TRANSFER
  CASH
  CREDIT_CARD
  CHEQUE
  OTHER
}

enum DeptPaymentType {
  FULL
  INSTALLMENTS
}

enum DeptInstallmentStatus {
  PENDING
  PAID
  OVERDUE
}

model DepartmentPayment {
  id              String             @id @default(cuid())
  amount          Float
  paidAmount      Float              @default(0)
  status          DeptPaymentStatus  @default(PENDING)
  paymentMethod   DeptPaymentMethod  @default(BANK_TRANSFER)
  paymentType     DeptPaymentType    @default(FULL)
  installmentCount Int               @default(1)
  dueDate         DateTime?
  notes           String?            @db.Text
  receiptUrl      String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  departmentId String
  department   Department @relation("DepartmentPayments", fields: [departmentId], references: [id])

  clientId String
  client   User   @relation("ClientDeptPayments", fields: [clientId], references: [id])

  projectId String?
  project   Project? @relation("ProjectDeptPayments", fields: [projectId], references: [id])

  serviceId String?
  service   Service? @relation("ServiceDeptPayments", fields: [serviceId], references: [id])

  createdById String?
  createdBy   User?  @relation("CreatedDeptPayments", fields: [createdById], references: [id])

  installments DeptPaymentInstallment[]

  @@map("department_payments")
}

model DeptPaymentInstallment {
  id        String                @id @default(cuid())
  amount    Float
  dueDate   DateTime
  paidDate  DateTime?
  status    DeptInstallmentStatus @default(PENDING)
  notes     String?               @db.Text
  createdAt DateTime              @default(now())

  paymentId String
  payment   DepartmentPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("dept_payment_installments")
}

// ═══ Document Management System (Investment Department) ═══

enum DocTypeKind {
  FILE
  TEXT
}

enum DocUploader {
  CLIENT
  EXECUTOR
  BOTH
}

enum DocVisibility {
  ALL
  EXECUTORS_AND_ADMIN
  ADMIN_ONLY
  CLIENT_AND_ADMIN
}

enum DocStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  RE_UPLOAD_REQUIRED
}

model DocType {
  id             String        @id @default(cuid())
  name           String
  description    String?       @db.Text
  kind           DocTypeKind   @default(FILE)
  sampleImageUrl String?       @db.Text
  instructions   String?       @db.Text
  fields         String?       @db.Text
  isConfidential Boolean       @default(false)
  whoCanUpload   DocUploader   @default(BOTH)
  whoCanView     DocVisibility @default(EXECUTORS_AND_ADMIN)
  isRequired     Boolean       @default(false)
  displayOrder   Int           @default(0)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  departmentId String
  department   Department @relation("DepartmentDocTypes", fields: [departmentId], references: [id])

  groupId String?
  group   DocumentGroup? @relation(fields: [groupId], references: [id])

  projectDocuments ProjectDocument[]

  @@map("document_types")
}

model DocumentGroup {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departmentId String
  department   Department @relation("DepartmentDocGroups", fields: [departmentId], references: [id])

  docTypes DocType[]

  @@map("document_groups")
}

model ProjectDocument {
  id                       String    @id @default(cuid())
  kind                     DocTypeKind
  fileUrl                  String?   @db.Text
  textData                 String?   @db.Text
  uploadedOnBehalfOfClient Boolean   @default(false)
  status                   DocStatus @default(PENDING_REVIEW)
  rejectionReason          String?   @db.Text
  isSharedWithClient       Boolean   @default(false)
  reviewedAt               DateTime?
  version                  Int       @default(1)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  documentTypeId String
  documentType   DocType @relation(fields: [documentTypeId], references: [id])

  uploadedById String?
  uploadedBy   User?  @relation("DocUploader", fields: [uploadedById], references: [id])

  reviewedById String?
  reviewedBy   User?  @relation("DocReviewer", fields: [reviewedById], references: [id])

  partnerId String?
  partner   ProjectPartner? @relation(fields: [partnerId], references: [id])

  @@map("project_documents")
}

// ===== Personal todo space =====
// A lightweight per-user todo list (Microsoft To Do style) that is
// completely independent of Task / Project. Each row is owned by one
// user; an optional `requestedBy` records who asked for it (e.g. a
// manager passing on an ad-hoc errand). Recurrence metadata is stored
// here but the cron that materializes daily instances lives in
// /api/cron/recurring-tasks.
model PersonalTask {
  id                 String    @id @default(cuid())
  ownerId            String
  owner              User      @relation("PersonalTaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  title              String
  description        String?

  // Scheduling — dueDate carries the calendar day; dueTime is "HH:mm"
  // when the user wants a specific clock time, otherwise null.
  dueDate            DateTime?
  dueTime            String?

  // Lifecycle — kept as String (not enum) to mirror the rest of the
  // codebase's lightweight status fields and avoid an enum migration.
  status             String    @default("PENDING") // PENDING | IN_PROGRESS | DONE
  completedAt        DateTime?

  // Optional "who asked for this" pointer.
  requestedById      String?
  requestedBy        User?     @relation("PersonalTaskRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  // Recurrence metadata — surface only; daily materialization is the
  // cron's job.
  isRecurring        Boolean   @default(false)
  recurrencePattern  String?   // DAILY | WEEKLY | MONTHLY
  recurrenceDays     String?   // JSON array, e.g. "[0,1,2,3,4]" for WEEKLY

  priority           String    @default("NORMAL") // LOW | NORMAL | HIGH

  notes              String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([ownerId, status])
  @@index([ownerId, dueDate])
  @@map("personal_tasks")
}
