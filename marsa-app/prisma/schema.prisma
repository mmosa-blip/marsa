generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Enums =====

enum Role {
  ADMIN
  MANAGER
  BRANCH_MANAGER
  CLIENT
  EXECUTOR
  EXTERNAL_PROVIDER
  FINANCE_MANAGER
  TREASURY_MANAGER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPhase {
  CONTRACT
  PAYMENTS
  CONTRACT_APPROVAL
  SERVICES
  PROVIDERS
  MANAGER
  EXECUTION
  COMPLETED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  WAITING
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
  WAITING_EXTERNAL
}

enum ServiceType {
  NORMAL
  START
  END
}

model UserService {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("ExecutorServices", fields: [userId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service  @relation("ServiceExecutors", fields: [serviceId], references: [id], onDelete: Cascade)
  serviceTemplateId  String?
  serviceTemplate    ServiceTemplate?  @relation("TemplateExecutors", fields: [serviceTemplateId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@unique([userId, serviceId])
  @@map("user_services")
}

enum TaskExecutionMode {
  SEQUENTIAL
  PARALLEL
  INDEPENDENT
}

enum RequirementType {
  DOCUMENT
  PAYMENT
  SIGNATURE
  CUSTOM
}

enum RequirementStatus {
  PENDING
  COMPLETED
  WAIVED
}

enum MilestoneType {
  SERVICE
  PAYMENT
  APPROVAL
}

enum MilestoneStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  PENDING_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum LeaveType {
  ANNUAL
  SICK
  EMERGENCY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ReminderType {
  RESIDENCY_EXPIRY
  INSURANCE_EXPIRY
  LICENSE_EXPIRY
  CONTRACT_RENEWAL
  CUSTOM
}

enum ReminderStatus {
  PENDING
  NOTIFIED
  COMPLETED
  OVERDUE
}

enum ReminderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CREDIT_CARD
  CHECK
}

enum AuthorizationType {
  FULL
  PER_SERVICE
  NONE
}

enum DocumentType {
  COMMERCIAL_REGISTER
  MUNICIPAL_LICENSE
  ZAKAT_CERTIFICATE
  INSURANCE_CERTIFICATE
  CHAMBER_CERTIFICATE
  LEASE_CONTRACT
  CIVIL_DEFENSE
  SAUDIZATION
  GOSI_CERTIFICATE
  CUSTOM
}

enum DocumentStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  PENDING_RENEWAL
}

enum CashierPaymentMethod {
  CASH
  MADA
  BANK_TRANSFER
  DEFERRED
}

enum TransactionStatus {
  COMPLETED
  DEFERRED
  CANCELLED
}

enum WorkflowType {
  SEQUENTIAL
  INDEPENDENT
}

enum PaymentRequestStatus {
  PENDING_SUPERVISOR
  PENDING_FINANCE
  PENDING_TREASURY
  APPROVED
  PAID
  REJECTED
}

enum NotificationType {
  NEW_TASK
  TASK_UPDATE
  PROJECT_STATUS_CHANGE
  INVOICE_DUE
  INVOICE_PAID
  REMINDER_UPCOMING
  DOCUMENT_EXPIRING
  NEW_MESSAGE
  PAYMENT_REQUEST_UPDATE
  TASK_REJECTED
  TASK_TRANSFER_REQUEST
  TASK_TRANSFER_APPROVED
  TASK_TRANSFER_REJECTED
  ESCALATION_ALERT
}

enum TransferStatus {
  PENDING_ADMIN
  PENDING_TARGET
  APPROVED
  REJECTED_BY_ADMIN
  REJECTED_BY_TARGET
  CANCELLED
}

enum ServiceRequestStatus {
  PENDING
  REVIEWING
  AWAITING_PAYMENT
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ===== Models =====

model User {
  id                     String            @id @default(cuid())
  phone                  String            @unique
  password               String
  name                   String
  role                   Role              @default(CLIENT)
  // Human-readable client number — only meaningful when role = CLIENT.
  // Sequential, used as the 3-digit segment of Project.projectCode.
  clientNumber           Int?              @unique
  email                  String?
  avatar                 String?           @db.Text
  authorizationType      AuthorizationType @default(NONE)
  authorizationGrantedAt DateTime?
  authorizationSignature String?           @db.Text
  isExternal             Boolean           @default(false)
  specialization         String?
  costPerTask            Float?
  bankName               String?
  bankIban               String?
  signatureImage         String?           @db.Text
  stampImage             String?           @db.Text
  isActive               Boolean           @default(true)
  // Force-password-change flag. Set to true whenever the system generates
  // a password on the user's behalf (Excel import, cashier quick-create,
  // admin-created accounts). Login flow should redirect to a change-
  // password screen until the user has chosen their own password.
  mustChangePassword     Boolean           @default(false)
  deletedAt              DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  // علاقة المشرف (مزودين خارجيين)
  supervisorId        String?
  supervisor          User?    @relation("SupervisorExternal", fields: [supervisorId], references: [id])
  supervisedProviders User[]   @relation("SupervisorExternal")

  // علاقة مدير الفرع — BRANCH_MANAGER يشرف على مجموعة منفذين
  supervisorUserId    String?
  supervisorUser      User?    @relation("BranchTeam", fields: [supervisorUserId], references: [id])
  subordinates        User[]   @relation("BranchTeam")

  // العلاقات
  ownedCompanies  Company[]  @relation("CompanyOwner")
  clientProjects  Project[]  @relation("ProjectClient")
  managedProjects Project[]  @relation("ProjectManager")
  assignedTasks   Task[]     @relation("TaskAssignee")
  reminders       Reminder[] @relation("ReminderCreator")
  invoices        Invoice[]  @relation("InvoiceCreator")
  clientServices  Service[]  @relation("ServiceClient")
  clientInvoices  Invoice[]  @relation("InvoiceClient")
  clientReminders      Reminder[]            @relation("ReminderClient")
  documents            Document[]            @relation("DocumentOwner")
  cashierTransactions  CashierTransaction[]  @relation("TransactionClient")
  cashierOperations    CashierTransaction[]  @relation("TransactionCashier")
  qualifiedServices    ServiceTemplateEmployee[] @relation("QualifiedServices")
  escalationServices   ServiceTemplateEscalation[] @relation("EscalationServices")
  createdProjectTemplates ProjectTemplate[] @relation("ProjectTemplateCreator")
  providerTaskCosts       TaskCost[]        @relation("ProviderTaskCosts")
  providerPaymentRequests PaymentRequest[]  @relation("ProviderPaymentRequests")
  requestedPayments       PaymentRequest[]  @relation("RequestedPayments")
  notifications           Notification[]
  conversations           Conversation[]    @relation("ConversationUsers")
  sentMessages            Message[]
  seenMessages            Message[]         @relation("SeenMessages")
  closedProjects          Project[]         @relation("ProjectCloser")
  executorServices        UserService[]     @relation("ExecutorServices")

  // علاقات نظام المهام
  providedServices        ServiceProviderMapping[] @relation("ProviderMappings")
  taskRejections          TaskRejection[]          @relation("TaskRejections")
  transfersRequested      TaskTransferRequest[]    @relation("TransferRequester")
  transfersTargeted       TaskTransferRequest[]    @relation("TransferTarget")
  transfersReviewed       TaskTransferRequest[]    @relation("TransferReviewer")
  delegationsGranted      TaskTransferDelegation[] @relation("DelegationFrom")
  delegationsReceived     TaskTransferDelegation[] @relation("DelegationTo")

  // علاقات طلبات الخدمات
  clientServiceRequests   ServiceRequest[]           @relation("ClientServiceRequests")
  assignedServiceRequests ServiceRequest[]           @relation("AssignedServiceRequests")

  // علاقات العقود
  contractTemplates       ContractTemplate[]         @relation("TemplateCreator")
  issuedContracts         Contract[]                 @relation("ContractIssuer")
  clientContracts         Contract[]                 @relation("ContractClient")
  approvedContracts       Contract[]                 @relation("ContractApprover")

  // علاقات تتبع الوقت
  timeLogs                TaskTimeLog[]

  startedTasks            Task[]            @relation("TaskStarter")
  taskAssignments         TaskAssignment[]

  // علاقات الملاحق
  createdAddenda          ContractAddendum[] @relation("AddendumCreator")
  approvedAddenda         ContractAddendum[] @relation("AddendumApprover")

  // علاقات التذاكر
  clientTickets         Ticket[]        @relation("ClientTickets")
  agentTickets          Ticket[]        @relation("AgentTickets")
  ticketMessages        TicketMessage[] @relation("TicketMessageSender")

  // علاقات الصلاحيات
  permissions            UserPermission[]  @relation("UserPermissions")
  permissionsGranted     UserPermission[]  @relation("PermissionGranter")
  auditLogs              AuditLog[]
  clientDocuments    ClientDocument[] @relation("ClientDocuments")
  uploadedDocuments  ClientDocument[] @relation("DocumentUploader")

  providerLinks      TaskExternalProvider[] @relation("ProviderLinks")
  providerLinksMade  TaskExternalProvider[] @relation("ProviderLinkCreator")
  remindersSent      ProviderReminder[]     @relation("ReminderSender")
  governmentHolds    TaskGovernmentHold[]   @relation("GovernmentHoldCreator")
  governmentUpdates  GovernmentUpdate[]     @relation("GovUpdateCreator")

  editedPolicies       SystemPolicy[]       @relation("PolicyEditor")
  policyNotifications  PolicyNotification[] @relation("PolicyNotifications")
  departments          UserDepartment[]     @relation("UserDepartments")
  assignedOpportunities Opportunity[]       @relation("OpportunityAssignee")
  clientOpportunities   Opportunity[]       @relation("OpportunityClient")
  clientDeptPayments    DepartmentPayment[] @relation("ClientDeptPayments")
  createdDeptPayments   DepartmentPayment[] @relation("CreatedDeptPayments")
  uploadedDocs          ProjectDocument[]   @relation("DocUploader")
  reviewedDocs          ProjectDocument[]   @relation("DocReviewer")

  assignmentPools       DepartmentAssignmentPool[]

  pausedProjects        ProjectPause[]      @relation("PausedProjects")
  resumedProjects       ProjectPause[]      @relation("ResumedProjects")
  revertedTasks         Task[]              @relation("RevertedTasks")

  // Personal todo space — independent of project Tasks.
  personalTasksOwned     PersonalTask[]    @relation("PersonalTaskOwner")
  personalTasksRequested PersonalTask[]    @relation("PersonalTaskRequester")

  @@index([role, isActive, deletedAt])
  @@index([supervisorUserId, isActive])
  @@map("users")
}

model Company {
  id                 String   @id @default(cuid())
  name               String
  commercialRegister String?  @unique
  sector             String?
  createdAt          DateTime @default(now())
  deletedAt          DateTime?

  // العلاقات
  ownerId String
  owner   User   @relation("CompanyOwner", fields: [ownerId], references: [id])

  employees Employee[]
  reminders Reminder[]
  invoices  Invoice[]
  documents Document[]

  @@map("companies")
}

model Service {
  id                  String   @id @default(cuid())
  name                String
  description         String?  @db.Text
  category            String?
  price               Float?
  duration            Int?
  isActive            Boolean  @default(true)
  isPublic            Boolean  @default(true)
  type                ServiceType @default(NORMAL)
  serviceTemplateId   String?
  serviceTemplate     ServiceTemplate? @relation("ServiceInstances", fields: [serviceTemplateId], references: [id])
  status              String?  @default("PENDING")
  serviceOrder        Int      @default(0)
  // SEQUENTIAL = tasks within the service run one after the other.
  // PARALLEL    = tasks within the service may run simultaneously,
  //               but the service still waits for the previous service.
  // INDEPENDENT = tasks bypass every dependency check.
  executionMode       TaskExecutionMode @default(SEQUENTIAL)
  // Background services run from the start of the project regardless
  // of where they sit in the service order. Their tasks are sequential
  // internally but don't block or wait for other services.
  isBackground        Boolean           @default(false)
  createdAt           DateTime @default(now())
  deletedAt           DateTime?

  // العلاقات
  clientId String
  client   User   @relation("ServiceClient", fields: [clientId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  tasks              Task[]
  projectMilestones  ProjectMilestone[]
  executors          UserService[]  @relation("ServiceExecutors")
  deptPayments       DepartmentPayment[] @relation("ServiceDeptPayments")

  @@index([projectId, deletedAt])
  @@map("services")
}

model Project {
  id           String          @id @default(cuid())
  // Human-readable project code: YYYY + clientNo(3) + deptNo(2) +
  // contractNo(3) + projectSeq(4) = 16 chars. Generated by
  // src/lib/project-code.ts at create time and regenerated when the
  // linked contract's number is edited from the project detail page.
  projectCode  String?         @unique
  // Sequential counter — the 4-digit tail of projectCode.
  projectSeq   Int?            @unique
  name         String
  description  String?         @db.Text
  status       ProjectStatus   @default(DRAFT)
  phase        ProjectPhase    @default(CONTRACT)
  priority     ProjectPriority @default(MEDIUM)
  workflowType WorkflowType    @default(SEQUENTIAL)
  totalPrice   Float?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  // حقول SLA العقد
  contractStartDate    DateTime?
  contractDurationDays Int?
  contractEndDate      DateTime?

  isQuickService       Boolean         @default(false)

  // حقول إغلاق المشروع
  closedAt     DateTime?
  closureNotes String?         @db.Text
  closedById   String?
  closedBy     User?           @relation("ProjectCloser", fields: [closedById], references: [id])

  // العلاقات
  clientId String
  client   User   @relation("ProjectClient", fields: [clientId], references: [id])

  managerId String?
  manager   User?  @relation("ProjectManager", fields: [managerId], references: [id])

  templateId String?
  template   ProjectTemplate? @relation(fields: [templateId], references: [id])

  contractId String?
  contract   Contract? @relation("ProjectContract", fields: [contractId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  tasks        Task[]
  invoices     Invoice[]
  services     Service[]
  conversation Conversation?

  // علاقات إدارة المشاريع المتقدمة
  milestones         ProjectMilestone[]
  serviceRequest     ServiceRequest?
  contracts          Contract[]
  deptPayments       DepartmentPayment[] @relation("ProjectDeptPayments")
  paymentSchedule    ProjectPaymentSchedule[]
  documents          ProjectDocument[]
  partners           ProjectPartner[]
  pauses             ProjectPause[]

  // Formal pause/resume system — isPaused is the fast boolean the
  // operations room and executor views gate on, while the ProjectPause
  // history table carries the per-event detail.
  isPaused           Boolean  @default(false)

  @@index([clientId, status])
  @@index([departmentId, status])
  @@index([deletedAt, status])
  @@map("projects")
}

model ProjectPause {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reason      String    // PAYMENT_DELAY | CLIENT_REQUEST | OTHER
  notes       String?   @db.Text
  startDate   DateTime  @default(now())
  endDate     DateTime?
  pausedById  String
  pausedBy    User      @relation("PausedProjects", fields: [pausedById], references: [id])
  resumedById String?
  resumedBy   User?     @relation("ResumedProjects", fields: [resumedById], references: [id])
  createdAt   DateTime  @default(now())

  @@map("project_pauses")
}

model ProjectPartner {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  documents ProjectDocument[]

  @@map("project_partners")
}

enum PaymentScheduleStatus {
  PENDING
  PAID
  OVERDUE
}

model ProjectPaymentSchedule {
  id        String                @id @default(cuid())
  amount    Float
  dueDate   DateTime
  paidDate  DateTime?
  status    PaymentScheduleStatus @default(PENDING)
  label     String?
  notes     String?               @db.Text
  gateForServiceOrder Int?
  createdAt DateTime              @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_payment_schedules")
}

model Task {
  id        String       @id @default(cuid())
  title     String
  status    TaskStatus   @default(TODO)
  priority  TaskPriority @default(MEDIUM)
  order          Int               @default(0)
  executionMode  TaskExecutionMode @default(SEQUENTIAL)
  sameDay        Boolean           @default(false)
  dueDate        DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  // Soft-delete marker. Set when a parent service is soft-deleted so
  // the task disappears from queues without removing the row + its
  // history (time logs, audit, etc.).
  deletedAt DateTime?

  // حقل الجهة الخارجية
  externalEntity String?

  // العلاقات
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  // Optional link to the TaskTemplate this Task was instantiated from.
  // Used to look up completion requirements defined on the template.
  taskTemplateId String?
  taskTemplate   TaskTemplate? @relation(fields: [taskTemplateId], references: [id], onDelete: SetNull)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  assigneeId String?
  assignedAt DateTime?
  acceptedAt DateTime?
  assignee   User?  @relation("TaskAssignee", fields: [assigneeId], references: [id])

  dependsOnId    String?
  dependsOn      Task?  @relation("TaskDependency", fields: [dependsOnId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  dependentTasks Task[] @relation("TaskDependency")

  startedById    String?
  startedBy      User?  @relation("TaskStarter", fields: [startedById], references: [id])

  assignments    TaskAssignment[]

  taskCosts        TaskCost[]
  rejections       TaskRejection[]
  transferRequests TaskTransferRequest[]
  timeLogs         TaskTimeLog[]
  timeSummary      TaskTimeSummary?
  linkedInstallment ContractPaymentInstallment? @relation("InstallmentTask")

  waitingMode        String?
  escalationLevel    Int       @default(0)
  lastEscalatedAt    DateTime?
  externalProviders  TaskExternalProvider[]
  governmentHolds    TaskGovernmentHold[]

  requirementValues  TaskRequirementValue[]

  // Task-level grace period — executor requests extra days when overdue
  taskGraceDays      Int?
  taskGraceEnd       DateTime?
  taskGraceApproved  Boolean   @default(false)
  taskGraceReason    String?   @db.Text

  // Revert audit — tracks who reverted a DONE task back to IN_PROGRESS
  revertedAt         DateTime?
  revertedById       String?
  revertedBy         User?     @relation("RevertedTasks", fields: [revertedById], references: [id])
  revertReason       String?   @db.Text

  @@index([assigneeId, status])
  @@index([projectId, deletedAt])
  @@index([serviceId, status])
  @@index([dueDate, status])
  @@map("tasks")
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
  @@map("task_assignments")
}

model Employee {
  id                  String         @id @default(cuid())
  name                String
  nationality         String?
  nationalId          String?        @unique
  dateOfBirth         DateTime?
  jobTitle            String?
  department          String?
  hireDate            DateTime?
  baseSalary          Float?
  housingAllowance    Float?
  transportAllowance  Float?
  phone               String?
  email               String?
  status              EmployeeStatus @default(ACTIVE)
  passportNumber      String?
  residencyExpiry     DateTime?
  insuranceExpiry     DateTime?
  avatar              String?        @db.Text
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  leaveRequests LeaveRequest[]
  attendances   Attendance[]
  reminders     Reminder[]
  documents     EmployeeDocument[]

  @@map("employees")
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  name        String
  url         String   @db.Text
  type        String?
  size        Int?
  category    String?
  expiryDate  DateTime?
  createdAt   DateTime @default(now())

  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_documents")
}

model LeaveRequest {
  id        String      @id @default(cuid())
  type      LeaveType
  startDate DateTime
  endDate   DateTime
  status    LeaveStatus @default(PENDING)
  reason    String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("leave_requests")
}

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  createdAt DateTime         @default(now())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("attendances")
}

model Reminder {
  id              String           @id @default(cuid())
  title           String
  description     String?          @db.Text
  type            ReminderType     @default(CUSTOM)
  dueDate         DateTime
  status          ReminderStatus   @default(PENDING)
  reminderDays    Int              @default(30)
  isRecurring     Boolean          @default(false)
  recurringMonths Int?
  priority        ReminderPriority @default(MEDIUM)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  clientId   String?
  client     User?    @relation("ReminderClient", fields: [clientId], references: [id])

  createdById String
  createdBy   User   @relation("ReminderCreator", fields: [createdById], references: [id])

  @@map("reminders")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  title         String
  description   String?       @db.Text
  subtotal      Float         @default(0)
  taxRate       Float         @default(15)
  taxAmount     Float         @default(0)
  totalAmount   Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  clientId    String?
  client      User?    @relation("InvoiceClient", fields: [clientId], references: [id])

  createdById String
  createdBy   User     @relation("InvoiceCreator", fields: [createdById], references: [id])

  items               InvoiceItem[]
  payments            Payment[]
  transaction         CashierTransaction?
  projectMilestones   ProjectMilestone[]

  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(cuid())
  description String @db.Text
  quantity    Float  @default(1)
  unitPrice   Float
  total       Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  method        PaymentMethod @default(BANK_TRANSFER)
  paymentDate   DateTime      @default(now())
  referenceNumber String?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Document {
  id              String         @id @default(cuid())
  title           String
  type            DocumentType   @default(CUSTOM)
  customTypeName  String?
  documentNumber  String?
